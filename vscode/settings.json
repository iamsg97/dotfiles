{
    "github.copilot.nextEditSuggestions.enabled": true,
    // ——— Core formatting: Biome (no Prettier) ———
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "modificationsIfAvailable",
    "editor.formatOnPaste": false,
    "editor.defaultFormatter": "biomejs.biome",

    // Language-specific formatters
    "[javascript]": { "editor.defaultFormatter": "biomejs.biome" },
    "[javascriptreact]": { "editor.defaultFormatter": "biomejs.biome" },
    "[typescript]": { "editor.defaultFormatter": "biomejs.biome" },
    "[typescriptreact]": { "editor.defaultFormatter": "biomejs.biome" },
    "[json]": { "editor.defaultFormatter": "biomejs.biome" },
    "[jsonc]": { "editor.defaultFormatter": "biomejs.biome" },
    "[html]": { "editor.defaultFormatter": "vscode.html-language-features" },
    "[css]": { "editor.defaultFormatter": "vscode.css-language-features" },
    "[scss]": { "editor.defaultFormatter": "vscode.css-language-features" },
    "[markdown]": { "editor.defaultFormatter": "vscode.markdown-language-features" },

    // Save actions: format with Biome, lint fixes with ESLint, organize imports (fast + reliable)
    "editor.codeActionsOnSave": {
        "source.organizeImports": "always",
        "source.fixAll.eslint": "always"
        // note: no "source.fixAll.biome" to avoid conflicts if ESLint is present
    },

    // ——— Editor & files ergonomics ———
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 1200,
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,
    "files.eol": "\n",
    "editor.tabSize": 4,
    "editor.detectIndentation": true,
    "editor.minimap.enabled": false,
    "editor.renderWhitespace": "boundary",
    "editor.cursorBlinking": "smooth",
    "editor.linkedEditing": true,
    "editor.stickyScroll.enabled": true,
    "editor.bracketPairColorization.enabled": true,
    "workbench.startupEditor": "none",
    "workbench.editor.enablePreview": true,
    "explorer.compactFolders": true,
    "telemetry.telemetryLevel": "off",

    // ——— TypeScript/JavaScript productivity ———
    "typescript.updateImportsOnFileMove.enabled": "always",
    "javascript.updateImportsOnFileMove.enabled": "always",
    "typescript.preferences.importModuleSpecifier": "shortest",
    "javascript.preferences.importModuleSpecifier": "shortest",
    "typescript.inlayHints.parameterNames.enabled": "literals",
    "typescript.inlayHints.variableTypes.enabled": false,
    "typescript.enablePromptUseWorkspaceTsdk": true,
    "tsserver.maxTsServerMemory": 3072,

    // ——— ESLint: lint only (Biome handles formatting) ———
    "eslint.useFlatConfig": true,
    "eslint.format.enable": false,
    "eslint.codeActionsOnSave.mode": "problems",
    "eslint.workingDirectories": [{ "mode": "auto" }],

    // ——— Performance: file watching & search ———
    "files.watcherExclude": {
        "**/.git/**": true,
        "**/node_modules/**": true,
        "**/dist/**": true,
        "**/build/**": true,
        "**/out/**": true,
        "**/.next/**": true,
        "**/.nuxt/**": true,
        "**/.svelte-kit/**": true,
        "**/.vite/**": true,
        "**/.turbo/**": true,
        "**/coverage/**": true,
        "**/.cache/**": true
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/dist": true,
        "**/build": true,
        "**/out": true,
        "**/.next": true,
        "**/.nuxt": true,
        "**/.svelte-kit": true,
        "**/.vite": true,
        "**/.turbo": true,
        "**/coverage": true
    },

    // ——— Git & terminal ———
    "git.autofetch": true,
    "git.confirmSync": false,
    "terminal.integrated.defaultProfile.linux": "bash",
    "terminal.integrated.scrollback": 10000,
    "terminal.integrated.gpuAcceleration": "auto",
    "console-ninja.featureSet": "Community",
    "chat.mcp.gallery.enabled": true,
    "workbench.iconTheme": "vscode-icons"
}
